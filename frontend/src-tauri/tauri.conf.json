{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GV Staff Monitoring Tool",
  "version": "0.6.52",
  "identifier": "com.gv.staffmonitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/tracker.html",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GV Staff Monitoring Tool",
        "url": "tracker.html",
        "width": 520,
        "height": 740,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "additionalBrowserArgs": "--auto-select-desktop-capture-source=\"Entire screen\""
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist"
    }
  }
}